{
  "name": "alpine_zones",
  "page": {"size": "11x17", "margin_mm": 24},
  "source": {"type": "photo",
             "params": {"n_bands": 5, "band_gamma": 1.25, "blur_mm": 1.4,
                        "region": {"close_mm": 2.5, "open_mm": 0.8,
                                   "min_area_mm2": 50, "simplify_mm": 0.5}}},
  "humanize": {"wobble_amp_mm": 0.14, "overshoot_prob": 0.1,
               "break_per_mm": 0.002},
  "zones": [
    {"name": "sky",
     "select": {"type": "hsv", "hue": [170, 260], "sat": [0.05, 1.0],
                "max_edge_density": 0.05, "top_connected": true,
                "smooth_mm": 3.0},
     "bands": [
       {"module": "fixed_hatch", "pen": "blue03",
        "params": {"angle_deg": 0, "spacing_mm": 1.0,
                   "spacing_jitter": 0.06},
        "tone_mod": {"low": 0.04, "high": 0.3, "seg_mm": 4.0}},
       {"module": "fixed_hatch", "pen": "blue03",
        "params": {"angle_deg": 0, "spacing_mm": 0.8,
                   "spacing_jitter": 0.06},
        "tone_mod": {"low": 0.05, "high": 0.35, "seg_mm": 4.0}},
       {"module": "fixed_hatch", "pen": "blue03",
        "params": {"angle_deg": 0, "spacing_mm": 0.7,
                   "spacing_jitter": 0.06}},
       {"module": "fixed_hatch", "pen": "blue03",
        "params": {"angle_deg": 0, "spacing_mm": 0.6,
                   "spacing_jitter": 0.06}},
       {"module": "fixed_hatch", "pen": "blue03",
        "params": {"angle_deg": 0, "spacing_mm": 0.55,
                   "spacing_jitter": 0.06}}
     ],
     "edges": null},
    {"name": "mountain", "select": {"type": "rest"},
     "bands": [
       {"module": "empty"},
       {"module": "fan_hatch", "pen": "blue03",
        "params": {"pivot": [0.42, 0.12], "spacing_mm": 1.0},
        "tone_mod": {"low": 0.08, "high": 0.4, "seg_mm": 3.0}},
       {"module": "fan_hatch", "pen": "blue03",
        "params": {"pivot": [0.42, 0.12], "spacing_mm": 0.75},
        "tone_mod": {"low": 0.1, "high": 0.5, "seg_mm": 3.0}},
       {"module": "fan_hatch", "pen": "black03",
        "params": {"pivot": [0.42, 0.12], "spacing_mm": 0.7}},
       {"module": "patch_hatch", "pen": "black05",
        "params": {"spacing_mm": 0.55, "snap_deg": 30, "patch_gap_mm": 0.3,
                   "cross_delta_deg": 65, "fallback_angle_deg": 48}}
     ],
     "edges": {"module": "contour_lines", "pen": "black03",
               "params": {"min_len_mm": 6.0},
               "humanize": {"wobble_amp_mm": 0.1, "overshoot_prob": 0.05}}}
  ]
}
